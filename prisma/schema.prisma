generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum PaymentStatus {
  CREATED
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELED
  CREATED_DEMO
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  MYTHIC
  LEGENDARY
}

model User {
  id          String   @id @default(cuid())
  steamId     String   @unique
  username    String
  avatar      String?
  balance     Int      @default(0)
  role        Role     @default(USER)
  isBlocked   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventory   InventoryItem[]
  openings    CaseOpening[]
  payments    PaymentIntent[]
  consents    UserConsent[]
  auditLogs   AuditLog[]
}

model UserConsent {
  id               String   @id @default(cuid())
  userId           String?
  steamId          String?
  isAdult          Boolean
  acceptedTerms    Boolean
  acceptedPrivacy  Boolean
  acceptedPersonalData Boolean
  acceptedPayments Boolean
  docsVersion      String
  ip               String?
  userAgent        String?
  createdAt        DateTime @default(now())

  user             User?    @relation(fields: [userId], references: [id])
}

model Case {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  price       Int
  image       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  items       CaseItem[]
  openings    CaseOpening[]
}

model CaseItem {
  id          String   @id @default(cuid())
  caseId      String
  name        String
  rarity      Rarity
  price       Int
  chanceBps   Int
  image       String?
  createdAt   DateTime @default(now())

  case        Case     @relation(fields: [caseId], references: [id])
}

model InventoryItem {
  id          String   @id @default(cuid())
  userId      String
  name        String
  rarity      Rarity
  price       Int
  image       String?
  source      String
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model CaseOpening {
  id          String   @id @default(cuid())
  userId      String
  caseId      String
  itemName    String
  itemRarity  Rarity
  itemPrice   Int
  serverSeedHash String
  clientSeed  String
  nonce       Int
  rollBps     Int
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  case        Case     @relation(fields: [caseId], references: [id])
}

model PaymentIntent {
  id          String   @id @default(cuid())
  userId      String
  provider    String
  amount      Int
  status      PaymentStatus @default(CREATED)
  externalId  String?
  comment     String?
  rawPayload   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model PromoCode {
  id          String   @id @default(cuid())
  code        String   @unique
  amount      Int
  maxUses     Int
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model BattleRoom {
  id          String   @id @default(cuid())
  title       String
  mode        String
  status      String
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  metadata    Json?
  ip          String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
}


model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromoRedemption {
  id          String   @id @default(cuid())
  userId      String
  promoCodeId String
  createdAt   DateTime @default(now())

  @@unique([userId, promoCodeId])
}

model TradeOffer {
  id          String   @id @default(cuid())
  userId      String
  type        String
  status      String   @default("CREATED")
  tradeUrl    String?
  externalId  String?
  payload     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminAction {
  id          String   @id @default(cuid())
  adminUserId String?
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
}


model MarketPurchase {
  id          String   @id @default(cuid())
  provider    String
  status      String   @default("CREATED")
  itemName    String
  itemPrice   Int
  maxPrice    Int?
  externalId  String?
  payload     Json?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model SkinCatalogItem {
  id          String   @id @default(cuid())
  marketHashName String @unique
  weapon      String
  skinName    String
  rarity      Rarity
  price       Int
  image       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Contract {
  id          String   @id @default(cuid())
  userId      String
  inputItems  Json
  outputName  String
  outputRarity Rarity
  outputPrice Int
  status      String   @default("COMPLETED")
  createdAt   DateTime @default(now())
}


model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DailyBonusClaim {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  streak    Int      @default(1)
  createdAt DateTime @default(now())
}

model ReferralProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  code        String   @unique
  totalEarned Int      @default(0)
  createdAt   DateTime @default(now())
}

model ReferralInvite {
  id          String   @id @default(cuid())
  inviterId   String
  invitedId   String   @unique
  code        String
  reward      Int      @default(0)
  createdAt   DateTime @default(now())
}

model BattleParticipant {
  id        String   @id @default(cuid())
  battleId  String
  userId    String
  score     Int      @default(0)
  status    String   @default("JOINED")
  createdAt DateTime @default(now())
}


model SkinClaim {
  id              String   @id @default(cuid())
  userId          String
  inventoryItemId String?
  originalName    String
  originalPrice   Int
  selectedName    String?
  selectedPrice   Int?
  refundCoins     Int      @default(0)
  status          String   @default("PENDING")
  tradeUrl        String?
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EconomySetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
